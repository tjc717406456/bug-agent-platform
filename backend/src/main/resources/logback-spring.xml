<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 复用 Spring Boot 自带的格式与控制台 appender，保持终端输出原样 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 运行日志目录，和用户上传的分析日志(workspace/logs)分开，互不干扰；可用环境变量 LOG_DIR 覆盖 -->
    <property name="LOG_DIR" value="${LOG_DIR:-./workspace/app-logs}"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/bug-agent.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 按天滚动，单文件超 50MB 再切分片 -->
            <fileNamePattern>${LOG_DIR}/bug-agent.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <!-- 最多留 14 天，历史总量封顶 2GB，到期/超量自动清理，防撑爆盘 -->
            <maxHistory>14</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
